@model PATTERNS.Domain.Booking

<style>
    :root {
        --bg-page: linear-gradient(135deg, #f5efe6, #e8dccb);
        --bg-card: #ffffffcc;
        --text-title: #5c4633;
        --text-subtitle: #6e5a46;
        --text-item: #4a3b2c;
        --border-color: #e6dcd0;
        --price-color: #8d6e54;
        --btn-bg: linear-gradient(90deg, #b89b7a, #8d6e54);
    }

    body.theme-dark {
        --bg-page: linear-gradient(135deg, #1a1a2e, #16213e);
        --bg-card: rgba(30, 30, 50, 0.92);
        --text-title: #e0d7ff;
        --text-subtitle: #a99fc0;
        --text-item: #d0c8e8;
        --border-color: #44415a;
        --price-color: #a89fff;
        --btn-bg: linear-gradient(90deg, #6c63ff, #48439e);
    }

    body {
        background: var(--bg-page);
        font-family: 'Segoe UI', sans-serif;
        transition: background 0.4s;
    }

    .result-card {
        max-width: 700px;
        margin: 60px auto;
        padding: 40px;
        background: var(--bg-card);
        backdrop-filter: blur(8px);
        border-radius: 16px;
        box-shadow: 0 15px 35px rgba(0,0,0,0.08);
        transition: background 0.4s;
    }

    h2 {
        text-align: center;
        color: var(--text-title);
        margin-bottom: 15px;
    }

    h3 {
        margin-top: 30px;
        color: var(--text-subtitle);
    }

    p {
        color: var(--text-item);
    }

    .booking-details {
        list-style: none;
        padding: 0;
    }

        .booking-details li {
            padding: 10px 0;
            border-bottom: 1px solid var(--border-color);
            color: var(--text-item);
        }

    .price {
        font-size: 20px;
        font-weight: bold;
        color: var(--price-color);
    }

    .back-link {
        display: inline-block;
        margin-top: 25px;
        text-decoration: none;
        padding: 10px 18px;
        border-radius: 8px;
        background: var(--btn-bg);
        color: white;
        transition: 0.3s;
    }

        .back-link:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 15px rgba(0,0,0,0.15);
        }
</style>

<!-- Применяем тему мгновенно до рендера -->
<script>
    (function () {
        function getCookie(name) {
            const match = document.cookie.match(new RegExp('(^| )' + name + '=([^;]+)'));
            return match ? match[2] : null;
        }
        if (getCookie('theme') === 'dark') {
            document.body.classList.add('theme-dark');
        }
    })();
</script>

<div class="result-card">
    <h2>@ViewBag.MessageTitle</h2>
    <p>@ViewBag.MessageBody</p>

    <h3>Booking Details</h3>
    <ul class="booking-details">
        <li><strong>Booking Code:</strong> @Model.BookingCode</li>
        <li><strong>Hotel:</strong> @Model.HotelName</li>
        <li><strong>Room:</strong> @Model.RoomName (@Model.RoomType)</li>
        <li><strong>Dates:</strong> @Model.CheckIn → @Model.CheckOut</li>
        <li><strong>Guests:</strong> @Model.Guests</li>
        <li><strong>Payment:</strong> @Model.PaymentMethodName</li>
        <li class="price"><strong>Total:</strong> @Model.TotalPrice EUR</li>
    </ul>

    <a asp-controller="Booking" asp-action="Index" class="back-link">
        Create Another Booking
    </a>
</div>