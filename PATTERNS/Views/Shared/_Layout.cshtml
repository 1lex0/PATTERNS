<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Hotel Booking</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/PATTERNS.styles.css" asp-append-version="true" />
    <style>
        .nav-link {
            color: #d6c7b7 !important;
            transition: 0.2s;
        }

            .nav-link:hover {
                color: #f5efe6 !important;
                background: rgba(255,255,255,0.1);
            }

        .active-link {
            background: rgba(255,255,255,0.15) !important;
            color: #f5efe6 !important;
        }

        body {
            margin-bottom: 0;
        }
    </style>
</head>
<body style="display: flex; flex-direction: column; min-height: 100vh;">
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark mb-3"
             style="background: linear-gradient(90deg, #3d2b1f, #5c4633); box-shadow: 0 2px 15px rgba(0,0,0,0.2);">
            <div class="container-fluid px-4">
                <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index"
                   style="color: #f5efe6; font-size: 18px; letter-spacing: 0.5px;">
                    🏨 Hotel Booking
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                        data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1 gap-1">
                        <li class="nav-item">
                            <a class="nav-link px-3 py-2 rounded @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active-link" : "")"
                               asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link px-3 py-2 rounded @(ViewContext.RouteData.Values["controller"]?.ToString() == "Hotels" ? "active-link" : "")"
                               asp-controller="Hotels" asp-action="Index">🏩 Hotels</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link px-3 py-2 rounded @(ViewContext.RouteData.Values["controller"]?.ToString() == "Booking" ? "active-link" : "")"
                               asp-controller="Booking" asp-action="Index">📅 Booking</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link px-3 py-2 rounded @(ViewContext.RouteData.Values["controller"]?.ToString() == "Pricing" ? "active-link" : "")"
                               asp-controller="Pricing" asp-action="Index">💰 Pricing</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link px-3 py-2 rounded @(ViewContext.RouteData.Values["controller"]?.ToString() == "BookingHistory" ? "active-link" : "")"
                               asp-controller="BookingHistory" asp-action="Index">📋 History</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link px-3 py-2 rounded @(ViewContext.RouteData.Values["controller"]?.ToString() == "BookingManage" ? "active-link" : "")"
                               asp-controller="BookingManage" asp-action="Index">⚙️ Manage</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link px-3 py-2 rounded @(ViewContext.RouteData.Values["controller"]?.ToString() == "Theme" ? "active-link" : "")"
                               asp-controller="Theme" asp-action="Index">🎨 Themes</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link px-3 py-2 rounded @(ViewContext.RouteData.Values["controller"]?.ToString() == "Composite" ? "active-link" : "")"
                               asp-controller="Composite" asp-action="Index">🏗️ Composite</a>
                        </li>
                    </ul>
                    <ul class="navbar-nav ms-auto align-items-center gap-2">
                        @if (Context.Session.GetString("UserName") != null)
                        {
                            <li class="nav-item">
                                <span style="color: #f5efe6; font-size: 14px; padding: 6px 14px;
                                             background: rgba(255,255,255,0.1); border-radius: 20px;">
                                    👤 @Context.Session.GetString("UserName")
                                </span>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link px-3 py-1 rounded"
                                   style="background: rgba(231,76,60,0.3); color: #f5c6c6 !important;"
                                   asp-controller="Auth" asp-action="Logout">Logout</a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link px-3 py-1 rounded"
                                   style="background: rgba(255,255,255,0.1); color: #f5efe6 !important;"
                                   asp-controller="Auth" asp-action="Login">Login</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link px-3 py-1 rounded fw-bold"
                                   style="background: linear-gradient(90deg, #b89b7a, #8d6e54); color: white !important;"
                                   asp-controller="Auth" asp-action="Register">Register</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container-fluid px-4" style="flex: 1;">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer style="background: linear-gradient(90deg, #3d2b1f, #5c4633); color: #d6c7b7;
                   padding: 16px 24px; font-size: 13px;">
        <div class="container-fluid px-4 d-flex justify-content-between align-items-center">
            <span>© 2026 — Hotel Booking Service</span>
            <span style="font-size: 12px; opacity: 0.7;">
                Creational · Structural · Behavioral Patterns
            </span>
            <a asp-controller="Home" asp-action="Privacy"
               style="color: #b89b7a; text-decoration: none;">Privacy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>