@model PATTERNS.Lab3.ChainOfResponsibility.AuthRequest
@{
    ViewData["Title"] = "Login";
}

<style>
    .auth-card {
        max-width: 480px;
        margin: 60px auto;
        padding: 40px;
        background: #ffffffcc;
        backdrop-filter: blur(8px);
        border-radius: 16px;
        box-shadow: 0 15px 35px rgba(0,0,0,0.12);
    }

    .auth-title {
        text-align: center;
        font-size: 26px;
        font-weight: 700;
        color: #5c4633;
        margin-bottom: 8px;
    }

    .auth-subtitle {
        text-align: center;
        font-size: 14px;
        color: #8d6e54;
        margin-bottom: 28px;
    }

    .form-group {
        margin-bottom: 16px;
    }

    label {
        display: block;
        font-weight: 500;
        color: #6e5a46;
        margin-bottom: 5px;
        font-size: 14px;
    }

    input {
        width: 100%;
        padding: 10px 14px;
        border-radius: 8px;
        border: 1px solid #d6c7b7;
        background: #fdfaf6;
        color: #4a3b2c;
        font-size: 15px;
        transition: 0.3s;
        box-sizing: border-box;
    }

        input:focus {
            outline: none;
            border-color: #b89b7a;
            box-shadow: 0 0 6px rgba(184,155,122,0.4);
        }

    .auth-btn {
        width: 100%;
        padding: 12px;
        margin-top: 8px;
        border: none;
        border-radius: 10px;
        background: linear-gradient(90deg, #b89b7a, #8d6e54);
        color: white;
        font-size: 16px;
        font-weight: 600;
        cursor: pointer;
        transition: 0.3s;
    }

        .auth-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.2);
        }

    .error-box {
        padding: 12px 16px;
        border-radius: 10px;
        background: #fbeaea;
        border: 1px solid #d88;
        color: #7a1f1f;
        margin-bottom: 20px;
        font-size: 14px;
    }

    .auth-link {
        text-align: center;
        margin-top: 20px;
        font-size: 14px;
        color: #8d6e54;
    }

        .auth-link a {
            color: #5c4633;
            font-weight: 600;
            text-decoration: none;
        }

    .chain-info {
        margin-top: 24px;
        padding: 14px;
        background: #f5efe6;
        border-radius: 10px;
        font-size: 13px;
        color: #6e5a46;
    }

        .chain-info strong {
            display: block;
            margin-bottom: 8px;
            color: #5c4633;
        }

    .chain-step {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 4px 0;
    }

    .chain-arrow {
        color: #b89b7a;
        font-weight: bold;
    }
</style>

<div class="auth-card">
    <div class="auth-title">Welcome Back</div>
    <div class="auth-subtitle">Sign in to manage your bookings</div>

    @if (ViewBag.Error != null)
    {
        <div class="error-box">⚠️ @ViewBag.Error</div>
    }

    <form method="post">
        <div class="form-group">
            <label>Email</label>
            <input name="Email" type="text" placeholder="you@example.com" required />
        </div>
        <div class="form-group">
            <label>Password</label>
            <input name="Password" type="password" placeholder="Your password" required />
        </div>
        <button type="submit" class="auth-btn">Sign In →</button>
    </form>

    <div class="auth-link">
        Don't have an account? <a asp-action="Register">Create one</a>
    </div>

    <div class="chain-info">
        <strong>⛓ Chain of Responsibility:</strong>
        <div class="chain-step"><span class="chain-arrow">→</span> EmailFormatHandler</div>
        <div class="chain-step"><span class="chain-arrow">→</span> EmailExistsHandler</div>
        <div class="chain-step"><span class="chain-arrow">→</span> PasswordVerifyHandler</div>
        <div class="chain-step"><span class="chain-arrow">→</span> SessionHandler</div>
    </div>
</div>